####################################################################
# WhiteSource Unified-Agent generated configuration file
####################################################################
resolveAllDependencies=false
archiveExtractionDepth=10
followSymbolicLinks=true
html.resolveDependencies=true

#---- NPM SPECIFIC -------
# Use NPM's dependency resolver which respects package-lock.json
# de-duplication instead of scanning node_modules via file system
npm.resolveDependencies=true
npm.includeDevDependencies=false
npm.runPreStep=true
npm.ignoreNpmLsErrors=true
npm.resolveLockFile=true

#---- MAVEN SPECIFIC -------
maven.resolveDependencies=false
maven.ignoredScopes=test provided system

wss.url=https://saas.whitesourcesoftware.com/agent
#------------------------------------------------------------------------
updateEmptyProject=false
projectPerFolder=false
#-- Always excluded
projectPerFolderExcludes=.vscode docs jar
projectName=domino-keep-admin-ui
#productName is set via env var WS_PRODUCTNAME
#projectTag=HCLLabs
#---------------- File name patterns to search ----------------
# Removed **/*.js **/*.ts **/*.tsx to prevent file-system scanning of node_modules.
# NPM dependencies are now resolved via npm.resolveDependencies=true instead.
includes=**/*.cpp **/*.java **/*.c **/*.dll **/*.h **/*.jar

###########
# General #
###########
scanComment=Scan on github opensource site

# Archives
archiveExtractionDepth=10

# Exclude node_modules from file-system scanning entirely
excludes=**/*sources.jar **/*javadoc.jar **/*.log **/mocha*.js **/node_modules/** **/monaco-editor-core/**

#-- Docker stuff
docker.scanImages=false
docker.includes=.*projectkeep-r12.*
docker.pull.enable=true
docker.pull.images=.*.*
docker.pull.maxImages=10

#-- Log settings
#log.files.level=info
log.files.maxFileSize=200
log.files.path=whitesource
